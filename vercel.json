{
  "version": 2,
  "builds": [
    {
      "src": "delivery-system/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/delivery-system/frontend/build/index.html"
    }
  ]
}
